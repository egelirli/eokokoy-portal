# Vercel Environment Variables
# Bu dosyayı kopyalayıp .env.local oluşturun (local geliştirme)
# Production değerlerini Vercel Dashboard > Settings > Environment Variables'a ekleyin

# Backend API URL (zorunlu)
# Local:      http://localhost:8080/api/v1
# Production: https://api.ekokoy.com/api/v1  (Railway / Render / VPS URL'nizi yazın)
VITE_API_URL=http://localhost:8080/api/v1

# Uygulama adı
VITE_APP_NAME=Ekoköy Portalı
